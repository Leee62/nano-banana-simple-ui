# Copy this file to `.env` for local development.
# Never commit real secrets to tracked env templates.
GEMINI_API_KEY=replace_with_your_real_key_in_local_env_only
PORT=8787

# Public runtime config injected into the built client through /app-config.js.
PUBLIC_APP_NAME=Nano Banana UI
PUBLIC_API_BASE_URL=/api
PUBLIC_DEFAULT_LOCALE=zh
